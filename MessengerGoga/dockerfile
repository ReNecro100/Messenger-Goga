FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Копируем ВСЮ папку MessengerGoga (со всем содержимым)
COPY ./MessengerGoga/ ./MessengerGoga/

# Устанавливаем зависимости
RUN pip install --no-cache-dir -r MessengerGoga/requirements.txt

# Копируем остальное (talking, static, manage.py и т.д.)
COPY . .

EXPOSE 8080

CMD ["uvicorn", "MessengerGoga.asgi:application", "--host", "0.0.0.0", "--port", "8080"]
